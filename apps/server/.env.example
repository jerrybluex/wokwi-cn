# D6 — local dev defaults
# Copy to .env and adjust for production.

# SQLite for MVP. Switch to "postgresql://user:pass@host/db" for D10 deploy.
DATABASE_URL="file:./dev.db"

# Used to sign JWT cookies. Replace with a long random string in production.
JWT_SECRET="dev-only-jwt-secret-replace-in-production"

# Frontend origin (CORS allowlist + cookie SameSite=None requires this).
WEB_ORIGIN="http://localhost:5173"

# ── D8: DeepSeek ──────────────────────────────────────────────────────────────
# Get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""
# Max tokens per AI response. Reduce if P95 latency > 5s. Default: 400
DEEPSEEK_MAX_TOKENS="400"
# Model name. Default "deepseek-chat". Sprint 收尾主理人指定 "deepseek-v4-pro"。
DEEPSEEK_MODEL="deepseek-chat"

# ── D10: Sentry ────────────────────────────────────────────────────────────────
# Get from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=""

# ── D12: Email (Resend) ────────────────────────────────────────────────────
# Get from https://resend.com/api-keys  (empty → stub mode, console.log only)
RESEND_API_KEY=""
# Must match a verified domain in your Resend account
EMAIL_FROM="Wokwi <noreply@wokwi-cn.example.com>"
# Optional — falls back to EMAIL_FROM
EMAIL_REPLY_TO=""
